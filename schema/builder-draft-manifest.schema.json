{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://akalynth/codex/builder-draft-manifest.schema.json",
  "title": "Akalynth Builder Draft Manifest v1",
  "description": "Private builder draft describing proposed world changes before operator review. Codex-side contract only; not live authority.",
  "type": "object",
  "required": [
    "schema_version",
    "object_id",
    "source_object",
    "packet_ref",
    "created_utc",
    "status",
    "preview_namespace",
    "changed_files",
    "abuse_review",
    "non_claims"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "builder-draft-manifest/v1" },
    "object_id": {
      "type": "string",
      "pattern": "^AKALYNTH_BUILDER_DRAFT_[A-Z0-9_]+$",
      "description": "Stable draft manifest identifier."
    },
    "source_object": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$",
      "description": "Parent codex object id (e.g. rookguard, high-city)."
    },
    "packet_ref": {
      "type": "string",
      "description": "Design anchor or packet ref this draft implements."
    },
    "created_utc": { "type": "string", "format": "date-time" },
    "status": {
      "enum": ["draft", "submitted", "in_review", "accepted", "rejected", "revise"],
      "description": "Builder workflow state for the draft manifest."
    },
    "preview_namespace": {
      "type": "string",
      "pattern": "^preview:",
      "description": "Isolated preview namespace; must not write to live lanes."
    },
    "map_deltas": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["room_id"],
        "properties": {
          "room_id": { "type": "string" },
          "cells": {
            "type": "array",
            "items": {
              "type": "array",
              "minItems": 2,
              "maxItems": 2,
              "items": { "type": "integer" }
            }
          },
          "note": { "type": "string" }
        }
      }
    },
    "objects": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "kind"],
        "properties": {
          "id": { "type": "string" },
          "kind": { "type": "string" },
          "text": { "type": "string" },
          "placement": {
            "type": "array",
            "minItems": 2,
            "maxItems": 2,
            "items": { "type": "integer" }
          }
        }
      }
    },
    "npc_lines": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["npc_id", "line_id", "text"],
        "properties": {
          "npc_id": { "type": "string" },
          "line_id": { "type": "string" },
          "text": { "type": "string" }
        }
      }
    },
    "quest_steps": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["step_id", "summary"],
        "properties": {
          "step_id": { "type": "string" },
          "summary": { "type": "string" },
          "locked_until": { "type": "string" }
        }
      }
    },
    "changed_files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256"],
        "properties": {
          "path": { "type": "string" },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        }
      }
    },
    "abuse_review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["grants_live_rewards", "grants_live_access"],
      "properties": {
        "grants_live_rewards": { "type": "boolean", "const": false },
        "grants_live_access": { "type": "boolean", "const": false },
        "notes": { "type": "string" }
      }
    },
    "non_claims": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    }
  }
}