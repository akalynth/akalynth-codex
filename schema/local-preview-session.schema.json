{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://akalynth/codex/local-preview-session.schema.json",
  "title": "Akalynth Local Preview Session v1",
  "description": "Offline/local builder preview evidence. Preview receipts are non-authoritative and excluded from chronicle unless referenced in operator review.",
  "type": "object",
  "required": [
    "schema_version",
    "session_id",
    "draft_manifest_ref",
    "started_utc",
    "ended_utc",
    "preview_only",
    "artifacts",
    "receipt_expectations",
    "non_claims"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "local-preview-session/v1" },
    "session_id": {
      "type": "string",
      "pattern": "^AKALYNTH_PREVIEW_[A-Z0-9_]+$"
    },
    "draft_manifest_ref": { "type": "string" },
    "started_utc": { "type": "string", "format": "date-time" },
    "ended_utc": { "type": "string", "format": "date-time" },
    "preview_only": { "type": "boolean", "const": true },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["manifest_checksum", "replay_log_ref", "screenshots"],
      "properties": {
        "manifest_checksum": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "replay_log_ref": { "type": "string" },
        "screenshots": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "abuse_review_note": { "type": "string" }
      }
    },
    "receipt_expectations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["receipt_type", "lane"],
        "properties": {
          "receipt_type": { "type": "string" },
          "lane": { "enum": ["preview_only", "live"] },
          "note": { "type": "string" }
        }
      }
    },
    "non_claims": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    }
  }
}