{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://akalynth/codex/council-execution-permit.schema.json",
  "title": "Akalynth Council Execution Permit (local ops) v1",
  "description": "Permit issued after quorum approval. Check adapter is read-only; deploy adapter requires human ack.",
  "type": "object",
  "required": [
    "schema_version",
    "object_id",
    "proposal_id",
    "approved_utc",
    "action_class",
    "action_params",
    "vote_tally",
    "execution_status",
    "adapter",
    "non_mutation_boundary"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "council-execution-permit/v1" },
    "object_id": {
      "type": "string",
      "pattern": "^AKALYNTH_COUNCIL_PERMIT_[A-Z0-9_]+$"
    },
    "proposal_id": {
      "type": "string",
      "pattern": "^AKALYNTH_COUNCIL_PROPOSAL_[A-Z0-9_]+$"
    },
    "approved_utc": { "type": "string", "format": "date-time" },
    "permit_expires_utc": { "type": "string", "format": "date-time" },
    "action_class": {
      "enum": [
        "lane:beta:check",
        "lane:staging:check",
        "lane:sim:check",
        "lane:beta:deploy",
        "lane:staging:deploy",
        "lane:beta:publish-account-play",
        "lane:staging:publish-account-play"
      ]
    },
    "action_params": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lane"],
      "properties": {
        "lane": { "enum": ["beta", "staging", "sim"] },
        "dry_run": { "type": "boolean" },
        "execution_ack_required": { "type": "boolean" }
      }
    },
    "vote_tally": {
      "type": "object",
      "additionalProperties": false,
      "required": ["approve", "reject", "abstain", "quorum_met"],
      "properties": {
        "approve": { "type": "number", "minimum": 0 },
        "reject": { "type": "number", "minimum": 0 },
        "abstain": { "type": "number", "minimum": 0 },
        "weighted_approve": { "type": "number", "minimum": 0 },
        "quorum_met": { "type": "boolean" }
      }
    },
    "execution_status": {
      "enum": [
        "pending",
        "check_passed",
        "check_failed",
        "ack_required",
        "deploy_skipped",
        "deploy_passed",
        "deploy_failed",
        "deploy_dry_run_passed",
        "publish_skipped",
        "publish_passed",
        "publish_failed",
        "publish_dry_run_passed",
        "expired",
        "blocked"
      ]
    },
    "executed_utc": { "type": "string", "format": "date-time" },
    "adapter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["script", "invoked_command"],
      "properties": {
        "script": { "type": "string" },
        "invoked_command": { "type": "string" },
        "exit_code": { "type": "integer" },
        "evidence_dir": { "type": "string" }
      }
    },
    "vote_receipt_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "prior_receipt_hash": { "type": ["string", "null"] },
    "receipt_hash": { "type": "string" },
    "treasury_ledger_entry_id": {
      "type": "string",
      "pattern": "^AKALYNTH_COUNCIL_LEDGER_[A-Z0-9_]+$",
      "description": "v2 ledger row appended on permit issuance."
    },
    "human_ack": {
      "$ref": "https://akalynth/codex/council-human-ack.schema.json",
      "description": "Deploy-class permits record explicit operator acknowledgment."
    },
    "reputation_resolution": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "source": {
          "enum": ["vote_receipt", "member_registry", "mixed"],
          "description": "How vote weights were resolved."
        },
        "members_dir": { "type": "string" },
        "resolved_weights": {
          "type": "object",
          "additionalProperties": { "type": "number", "minimum": 0 }
        }
      }
    },
    "non_mutation_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runtime_trees",
        "runtime_state",
        "key_config_custody",
        "deployment",
        "auto_execution"
      ],
      "properties": {
        "runtime_trees": {
          "enum": ["unchanged", "mutated", "dry_run_only"]
        },
        "runtime_state": {
          "enum": ["unchanged", "mutated", "dry_run_only"]
        },
        "key_config_custody": { "const": "unchanged" },
        "deployment": {
          "enum": ["not_performed", "performed", "dry_run_performed", "skipped"]
        },
        "auto_execution": { "const": "not_performed" }
      }
    }
  }
}