{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://akalynth/codex/builder-promotion-permit.schema.json",
  "title": "Akalynth Builder Promotion Permit v1",
  "description": "Operator-issued permit authorizing a lane-scoped builder promotion. Emitted only on accept; does not auto-publish.",
  "type": "object",
  "required": [
    "schema_version",
    "permit_id",
    "review_packet_id",
    "source_object",
    "lane_target",
    "issued_utc",
    "reviewer",
    "draft_manifest_checksum",
    "execution_status",
    "non_mutation_boundary",
    "non_claims"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "builder-promotion-permit/v1" },
    "permit_id": {
      "type": "string",
      "pattern": "^AKALYNTH_BUILDER_PERMIT_[A-Z0-9_]+$"
    },
    "review_packet_id": { "type": "string" },
    "source_object": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "lane_target": { "enum": ["beta", "staging"] },
    "issued_utc": { "type": "string", "format": "date-time" },
    "reviewer": { "type": "string" },
    "draft_manifest_checksum": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "execution_status": {
      "enum": ["permit_issued", "publish_skipped", "publish_performed"],
      "description": "publish_performed requires explicit operator invocation outside this gate."
    },
    "non_mutation_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["deployment", "lane_publish", "runtime_state"],
      "properties": {
        "deployment": { "enum": ["not_performed", "performed"] },
        "lane_publish": { "enum": ["not_performed", "skipped", "performed"] },
        "runtime_state": { "enum": ["unchanged", "mutated"] }
      }
    },
    "non_claims": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    }
  }
}